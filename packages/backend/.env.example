# Скопіюй у .env.local перед першим запуском

# Порт API
PORT=3000

# Origin фронтенду (для CORS). За замовчуванням Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173

# Шлях до SQLite-файлу. Підключиться у наступному кроці (TypeORM).
DATABASE_PATH=./storage/pcf.sqlite

# Папка для згенерованих звітів (PDF/CSV/JSON).
REPORTS_DIR=./storage/reports

# Рівень логування (error | warn | log | debug | verbose)
LOG_LEVEL=log
